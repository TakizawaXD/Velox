# Velox Supreme v4 — Variables de Entorno
# Copia este archivo a .env y completa con tus credenciales reales
# cp .env.example .env

# ─── Firebase ────────────────────────────────────────────────────
# Obtén estas credenciales en: https://console.firebase.google.com
# Proyecto → Configuración → Tus apps → SDK de Firebase

VITE_FIREBASE_API_KEY=AIzaSy_TU_API_KEY_AQUI
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# ─── Pasarela de Pagos (Opcional) ────────────────────────────────
# Wompi Colombia: https://wompi.com/es/co/desarrolladores
VITE_WOMPI_PUBLIC_KEY=pub_test_tu_key_aqui
